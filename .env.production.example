# ================================================================
# PRIMEBAZAAR — PRODUCTION ENVIRONMENT VARIABLES
# Copy these to Vercel → Project Settings → Environment Variables
# ================================================================

# ── Database (MongoDB Atlas) ─────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/primebazaar?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-hex-string-here
NEXTAUTH_SECRET=another-64-char-random-hex-string-here
NEXTAUTH_URL=https://your-domain.vercel.app

# ── Site URL (YOUR actual Vercel URL or custom domain) ───────────
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# ── Stripe (get from stripe.com) ─────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Cloudinary (get from cloudinary.com → Dashboard) ─────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── Email — Resend (get from resend.com) ─────────────────────────
RESEND_API_KEY=re_live_...

# ── Nepal Payments ───────────────────────────────────────────────
# eSewa LIVE (get from esewa.com.np → Merchant)
ESEWA_MERCHANT_CODE=your-merchant-code
ESEWA_SECRET_KEY=your-secret-key
ESEWA_PAYMENT_URL=https://epay.esewa.com.np/api/epay/main/v2/form
ESEWA_VERIFY_URL=https://esewa.com.np/api/epay/transaction/status/

# Khalti LIVE (get from khalti.com → Merchant Dashboard)
KHALTI_SECRET_KEY=live_secret_key_...
KHALTI_API_URL=https://khalti.com/api/v2

# ── SMS — Twilio (optional, for real OTP SMS) ────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Google OAuth (optional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Redis (optional, Upstash recommended for Vercel) ─────────────
# Get from: https://upstash.com → Redis → Connect
REDIS_URL=rediss://default:password@endpoint.upstash.io:6379
